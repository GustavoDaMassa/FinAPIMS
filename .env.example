# PostgreSQL
DATABASE_PASSWORD=changeme

# JWT — string longa e aleatória (mínimo 32 chars)
JWT_SECRET=changeme-use-a-long-random-string-here

# identity-service — chave para criar usuários admin via POST /auth/admin
MASTER_KEY=changeme

# Pluggy
PLUGGY_CLIENT_ID=your-pluggy-client-id
PLUGGY_CLIENT_SECRET=your-pluggy-client-secret
