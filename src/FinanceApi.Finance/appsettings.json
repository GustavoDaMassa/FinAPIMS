{
  "ConnectionStrings": {
    "Default": "Host=postgres;Port=5432;Database=financeapi;Username=postgres;Password=${DATABASE_PASSWORD};Search Path=finance"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "financeapi-identity",
    "Audience": "financeapi"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "ConsumerGroup": "finance-consumer",
    "Topics": {
      "WebhookEvents": "webhook.events"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "HotChocolate": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
