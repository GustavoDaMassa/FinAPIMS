{
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "financeapi-identity",
    "Audience": "financeapi"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "finance-route": {
        "ClusterId": "finance-cluster",
        "Match": {
          "Path": "/graphql/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "finance-import-route": {
        "ClusterId": "finance-cluster",
        "Match": {
          "Path": "/import/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "webhook-route": {
        "ClusterId": "webhook-cluster",
        "Match": {
          "Path": "/webhook/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": {
            "Address": "http://identity-service:8081"
          }
        }
      },
      "finance-cluster": {
        "Destinations": {
          "finance": {
            "Address": "http://finance-service:8082"
          }
        }
      },
      "webhook-cluster": {
        "Destinations": {
          "webhook": {
            "Address": "http://webhook-service:8083"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
