{
  "ConnectionStrings": {
    "Default": "Host=postgres;Port=5432;Database=financeapi;Username=postgres;Password=${DATABASE_PASSWORD};Search Path=identity"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "ExpirationHours": 24,
    "Issuer": "financeapi-identity",
    "Audience": "financeapi"
  },
  "App": {
    "MasterKey": "${MASTER_KEY}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
