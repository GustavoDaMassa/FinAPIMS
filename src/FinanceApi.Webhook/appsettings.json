{
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "Topics": {
      "WebhookEvents": "webhook.events"
    }
  },
  "Pluggy": {
    "BaseUrl": "https://api.pluggy.ai",
    "ClientId": "${PLUGGY_CLIENT_ID}",
    "ClientSecret": "${PLUGGY_CLIENT_SECRET}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
